{
  "name": "@airloom/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/main/main.cjs",
  "scripts": {
    "build:main": "tsdown src/main/main.ts --format cjs --out-dir dist/main --external electron && tsdown src/preload/preload.ts --format cjs --out-dir dist/preload --external electron",
    "build:renderer": "vite build",
    "build": "bun run build:main && bun run build:renderer",
    "dev": "bun run build && electron ."
  },
  "dependencies": {
    "@airloom/shared": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "tsdown": "^0.15.5",
    "typescript": "^5.8.2",
    "vite": "^6.2.0"
  }
}
